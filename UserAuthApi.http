@baseUrl = http://localhost:5030

### ============================================
### Register User
### ============================================

POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Usman Butt",
  "phoneNumber": "03001234567",
  "email": "usman@example.com",
  "password": "Usman@123"
}

### ============================================
### Login User
### ============================================

POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "usman@example.com",
  "password": "Usman@123"
}

### ============================================
### Copy JWT Token from Login Response
### ============================================

@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..O_bBESOL83D8suf18apRK5hbeNVludI7WFeeXJTKh0Q
### ============================================
### Future Protected API Test
### (Will work after ProfileController is added)
### ============================================

GET {{baseUrl}}/api/profile
Authorization: Bearer {{token}}

### Get Profile
GET {{baseUrl}}/api/profile
Authorization: Bearer {{token}}

### Update Profile
PUT {{baseUrl}}/api/profile
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "level": 10,
    "xp": 500,
    "coins": 2000,
    "gems": 50,
    "currentCharacter": "Knight"
}

